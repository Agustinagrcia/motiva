generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model Product {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  sku           String   @unique
  name          String
  color         String
  size          String
  costPrice     Float    
  multiplier    Float    
  price         Float    
  stock         Int      @default(0)
  minStock      Int      @default(3)
  createdAt     DateTime @default(now())
}